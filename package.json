{
  "name": "QAOpsPlaywright",
  "version": "1.0.0",
  "description": "Playwright E2E test automation framework",
  "main": "index.js",
  "scripts": {
    "test":          "npx playwright test --config=config/playwright.config.ts",
    "test:e2e":      "npx playwright test --config=config/playwright.config.ts tests/e2e/",
    "test:api":      "npx playwright test --config=config/playwright.config.ts tests/api/",
    "test:ui":       "npx playwright test --config=config/playwright.config.ts tests/ui/",
    "test:dev":      "TEST_ENV=dev npx playwright test --config=config/playwright.config.ts",
    "test:staging":  "TEST_ENV=staging npx playwright test --config=config/playwright.config.ts",
    "test:prod":     "TEST_ENV=prod npx playwright test --config=config/playwright.config.ts",
    "report":        "npx playwright show-report reports/html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "*",
    "@playwright/test": "^1.59.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^4.5.0"
  }
}
